# ============================================
# Email Dispatcher — Environment Configuration
# ============================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit the .env file. It contains your email passwords.

# Gmail — App Password (NOT your regular Gmail password!)
# How to generate: myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_GMAIL_PASS=xxxx xxxx xxxx xxxx

# Outlook (regular password or App Password if MFA is enabled)
SMTP_OUTLOOK_PASS=your_outlook_password

# Add one entry per registered account:
# SMTP_CUSTOM_ACCOUNT_PASS=...

# Backend port (default: 3001)
PORT=3001
